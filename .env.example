# ============================================================
# BiznesERP — Environment O'zgaruvchilar
# .env.example faylini .env ga ko'chirib to'ldiring
# ============================================================

# === DATABASE ===
DATABASE_URL="postgresql://erp_user:your_password@localhost:5432/erp_platform"
DB_PASSWORD="your_strong_password_here"

# === REDIS ===
REDIS_URL="redis://:your_redis_password@localhost:6379"
REDIS_PASSWORD="your_redis_password_here"

# === JWT (kamida 32 belgi) ===
JWT_SECRET="your_minimum_32_character_jwt_secret_key_here"
JWT_REFRESH_SECRET="another_minimum_32_character_refresh_secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# === AI ===
ANTHROPIC_API_KEY="sk-ant-api03-your_anthropic_api_key_here"

# === APP ===
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"
API_PREFIX="api/v1"

# === FAYL SAQLASH (MinIO) ===
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_BUCKET="erp-uploads"
MINIO_USE_SSL=false

# === EMAIL (ixtiyoriy) ===
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="BiznesERP <noreply@bizniserp.uz>"

# === SMS — Eskiz.uz (O'zbekiston) ===
ESKIZ_EMAIL="your@email.com"
ESKIZ_PASSWORD="eskiz_password"
ESKIZ_FROM="4546"

# === FRONTEND ===
VITE_API_URL="http://localhost:4000/api/v1"
VITE_WS_URL="http://localhost:4000"
VITE_APP_NAME="BiznesERP"
VITE_APP_VERSION="1.0.0"
