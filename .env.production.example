# ============================================================
# BiznesERP Production Environment
# Copy to .env.production and fill with real values
# Generate secrets: bash scripts/generate-secrets.sh
# ============================================================

# Database
DB_NAME=bizzo_prod
DB_USER=bizzo_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT (minimum 32 chars each)
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS

# MinIO
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# URLs
FRONTEND_URL=https://bizzo.uz
VITE_API_URL=https://bizzo.uz/api/v1
VITE_WS_URL=https://bizzo.uz

# Integrations
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
TELEGRAM_BOT_TOKEN=
DIDOX_API_KEY=

# Deploy notifications (optional)
DEPLOY_TELEGRAM_BOT_TOKEN=
DEPLOY_TELEGRAM_CHAT_ID=

# Domain (for certbot)
DOMAIN=bizzo.uz
CERTBOT_EMAIL=admin@bizzo.uz
