<h2 style="margin:0 0 16px;color:#0A0F1E">Hisob-faktura {{invoiceNumber}}</h2>
<p>Hurmatli {{customerName}},</p>
<p>Sizga yangi hisob-faktura yuborildi.</p>
<table style="width:100%;border-collapse:collapse;margin:20px 0">
  <tr style="background:#f3f4f6"><td style="padding:10px;border-bottom:1px solid #e5e7eb"><strong>Sana</strong></td><td style="padding:10px;border-bottom:1px solid #e5e7eb">{{issueDate}}</td></tr>
  <tr><td style="padding:10px;border-bottom:1px solid #e5e7eb"><strong>Muddat</strong></td><td style="padding:10px;border-bottom:1px solid #e5e7eb">{{dueDate}}</td></tr>
  <tr style="background:#f3f4f6"><td style="padding:10px"><strong>Summa</strong></td><td style="padding:10px;font-size:18px;color:#3B82F6"><strong>{{total}} soʻm</strong></td></tr>
</table>
<p style="text-align:center;margin:32px 0">
  <a href="{{link}}" style="display:inline-block;padding:12px 28px;background:#3B82F6;color:#ffffff;text-decoration:none;border-radius:8px;font-weight:600">Hisob-fakturani koʻrish</a>
</p>
